# Copy this file to .env (which is gitignored) and fill in real values.
# Each line is KEY=VALUE. Blank lines and lines starting with # are ignored.
# Values can optionally be wrapped in single or double quotes.
#
# Any key defined here shows up in the dropdown on a Secret Loader node
# (io.github.jaymcole.housegraph.graph.nodes.loader.SecretLoaderNode) in the app.

API_KEY=your_api_key_here
DATABASE_PASSWORD="your_database_password_here"
